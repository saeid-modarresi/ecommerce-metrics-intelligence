{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListBucketPrefixes",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["normalized/*", "processed/*"]
        }
      }
    },
    {
      "Sid": "ReadNormalized",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME/normalized/*"
    },
    {
      "Sid": "WriteProcessed",
      "Effect": "Allow",
      "Action": ["s3:PutObject"],
      "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME/processed/*"
    },
    {
      "Sid": "HeadProcessedForIdempotency",
      "Effect": "Allow",
      "Action": ["s3:HeadObject"],
      "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME/processed/*"
    }
  ]
}