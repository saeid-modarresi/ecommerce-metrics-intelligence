{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ListBucketForRawAndNormalized",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket"
            ],
            "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME",
            "Condition": {
                "StringLike": {
                    "s3:prefix": [
                        "raw/*",
                        "normalized/*"
                    ]
                }
            }
        },
        {
            "Sid": "ReadRawObjects",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject"
            ],
            "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME/raw/*"
        },
        {
            "Sid": "WriteAndReadNormalizedObjects",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject"
            ],
            "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME/normalized/*"
        }
    ]
}